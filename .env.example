# Required
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.5
OPENAI_ESTIMATOR_MODEL=
OPENAI_FALLBACK_MODEL=gpt-4.1-mini

# Optional -- fill in from OpenAI's current pricing page to enable
# estimated-cost logging on top of the always-on real token-count logging.
# Left blank, token usage is still logged but no dollar estimate is computed.
OPENAI_ESTIMATOR_MODEL_INPUT_COST_PER_1K=
OPENAI_ESTIMATOR_MODEL_OUTPUT_COST_PER_1K=
OPENAI_FALLBACK_MODEL_INPUT_COST_PER_1K=
OPENAI_FALLBACK_MODEL_OUTPUT_COST_PER_1K=
WEB_SEARCH_CONTEXT_SIZE=medium
ESTIMATOR_REASONING_EFFORT=low
OPTIMUS_OWNER_USERNAME=owner
OPTIMUS_OWNER_PASSWORD=replace_with_a_long_owner_password

# /goal Phase 8: a platform-side, read-only support operator account (see
# app/bootstrap_support.py). Leave blank to skip -- this is not required for
# normal shop operation. Never granted by a shop owner, never self-service.
OPTIMUS_SUPPORT_USERNAME=
OPTIMUS_SUPPORT_PASSWORD=

# Landon Motor Works identity and defaults
BUSINESS_NAME=Landon Motor Works
BUSINESS_TAGLINE=Mobile Mechanic Intelligence
LABOR_RATE=100.00
MOBILE_SERVICE_FEE=0.00
SHOP_SUPPLIES_PERCENT=0.00
PARTS_TAX_RATE=0.00

# Optimus owner-control behavior
AUTONOMY_MODE=owner_full_control
DIRECT_OWNER_CHAT_DEFAULT=true
AGENT_DELEGATION_ENABLED=true
MAX_AGENT_CONSULTATIONS=2
ALLOW_PUBLIC_HTTPS_PARTS_LINKS=true

# Synthetic test-account provisioning (off by default everywhere, including
# local dev and CI). Only turn this on in a throwaway/CI database -- it lets
# /api/test-support/* mint and delete synthetic owner/technician accounts
# with randomly generated credentials. Requires APP_ENV to be anything other
# than "production" as a second, independent guard -- both must be set.
OPTIMUS_TEST_ACCOUNT_PROVISIONING=false

# API and network behavior
DATABASE_URL=postgresql+psycopg://optimus:optimus_local@postgres:5432/optimus_os
REDIS_URL=redis://redis:6379/0
MAX_ESTIMATES_PER_MINUTE=20
MAX_LOGIN_ATTEMPTS_PER_MINUTE=10
MAX_SIGNUP_ATTEMPTS_PER_MINUTE=5
MAX_EMAIL_VERIFICATION_ATTEMPTS_PER_MINUTE=20
MAX_EMAIL_VERIFICATION_RESEND_ATTEMPTS_PER_HOUR=5
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
MAX_PASSWORD_RESET_ATTEMPTS_PER_HOUR=5
MAX_INVITATION_ACCEPTANCE_ATTEMPTS_PER_HOUR=20
ACCOUNT_LOCKOUT_FAILURE_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15
SHOP_INVITATION_TOKEN_TTL_HOURS=72
SESSION_TTL_HOURS=12
FRONTEND_ORIGIN=http://127.0.0.1:5173
SESSION_COOKIE_NAME=optimus_session
HTTP_TIMEOUT_SECONDS=20
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=2
MAX_JOB_TEXT_LENGTH=500
MAX_CHAT_TEXT_LENGTH=12000
MAX_WEB_RESULTS=20
APP_ENV=production
LOG_LEVEL=INFO

# Deployment-only: extra docker compose override file (relative to repo root)
# that scripts/optimusctl.sh appends to every compose command. Staging sets:
# COMPOSE_OVERRIDE_FILE=ops/docker-compose.staging.yml

# Square Invoices (sandbox only in this phase). Leave the token blank to keep
# the integration disabled; SQUARE_ENVIRONMENT=production is rejected until a
# separately approved go-live change.
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_TIMEOUT_SECONDS=20

# Square Subscriptions (sandbox only) -- bills a *shop* for using OptimusOS
# itself, unrelated to the customer-invoice integration above. Create a
# Catalog subscription plan with one variation per tier in the Square
# sandbox dashboard first; leave blank to keep that tier un-subscribable.
SQUARE_SOLO_PLAN_VARIATION_ID=
SQUARE_TEAM_PLAN_VARIATION_ID=
SQUARE_SHOP_PLAN_VARIATION_ID=

# Used only when ALLOW_PUBLIC_HTTPS_PARTS_LINKS=false.
PARTS_RETAILER_HOSTS=autozone.com,www.autozone.com,oreillyauto.com,www.oreillyauto.com,napaonline.com,www.napaonline.com,shop.advanceautoparts.com,advanceautoparts.com,www.advanceautoparts.com,rockauto.com,www.rockauto.com
